<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link rel="stylesheet" href="/style.css">
	<link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
	<title>Shared Folder</title>
</head>

<body>
	<%- include('partials/header') %>
	<h1 class="sharedTitle">Shared folder: <%= folderData.name %></h1>
	<main class="home ">

		<div class="openFolder readOnly" folderName="<%= folderData.name %>" folderId="<%= folderData.id %>">
			<% if (!folderData.folders.length && !folderData.files.length) {%>
			<p class="emptyMessage">This folder is empty</p>
			<%} %>

			<% if (folderData.folders.length) {%>
			<%- include('partials/readOnlyFolderRows', {folders: folderData.folders}) %>

			<% } %>

			<% if (folderData.files.length) {%>
			<%- include('partials/readOnlyFileRows', {files: folderData.files, parentShareId: shareId}) %>

			<% } %>
		</div>
	</main>
	<%- include('partials/footer') %>
</body>
<script src="/scripts/modifyDisplayValues.js" defer></script>

</html>