<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="stylesheet" href="/style.css">
	<link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
	<title>Sign Up</title>
</head>

<body>
	<%- include('partials/header') %>
	<main>
		<h1>Sign Up</h1>
		<form class="signUpForm" action="/signup" method="post">
			<label for="email">Email</label>
			<input type="email" name="email" />
			<% if (bodyErrors.emailErrors) {%>
			<%- include('partials/errors', {errors: bodyErrors.emailErrors}) %>
			<%} %>

			<label for="username">Username</label>
			<input type="text" name="username" required />
			<% if (bodyErrors.usernameErrors) {%>
			<%- include('partials/errors', {errors: bodyErrors.usernameErrors}) %>
			<%} %>

			<label for="password">Password</label>
			<input type="password" name="password" />
			<% if (bodyErrors.passwordErrors) {%>
			<%- include('partials/errors', {errors: bodyErrors.passwordErrors}) %>
			<%} %>

			<label for="confirmPassword">Confirm Password</label>
			<input type="password" name="confirmPassword">
			<% if (bodyErrors.confirmPasswordErrors) {%>
			<%- include('partials/errors', {errors: bodyErrors.confirmPasswordErrors}) %>
			<%} %>

			<button type="submit" class="submitBtn">Sign Up</button>
		</form>
		<span>Already have an account? </span><a href="/login" class="formAnchor">Log in</a>
	</main>
	<%- include('partials/footer') %>
</body>

</html>